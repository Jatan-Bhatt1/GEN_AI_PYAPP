# ===== LLM API Keys =====
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ===== Choose Default LLM Provider =====
# Options: "openai", "google", or "groq"
DEFAULT_LLM_PROVIDER=groq

# ===== Database =====
DATABASE_URL=postgresql://postgres:password@localhost:5432/enterprise_ai
REDIS_URL=redis://localhost:6379/0

# ===== Vector Store =====
CHROMA_PERSIST_DIR=./vectorstore
CHROMA_COLLECTION_NAME=enterprise_docs

# ===== LangSmith (Monitoring) =====
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=enterprise-ai-assistant

# ===== Web Search =====
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Auth =====
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ===== App Config =====
APP_ENV=development
APP_DEBUG=true
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

#=======Tools==========
OPENWEATHER_API_KEY=your_openweather_api_key_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM=your_email@gmail.com

#=======Memory System (Phase 5)==========
# How many recent messages to keep in buffer (per direction: 10 = 10 human + 10 AI)
MEMORY_WINDOW_SIZE=10
# Trigger summarization after this many total messages in a session
MEMORY_SUMMARY_THRESHOLD=20
# ChromaDB collection for conversation memory (keep separate from RAG docs)
MEMORY_COLLECTION_NAME=conversation_memory
# How long Redis buffer messages live (seconds). 86400 = 24h, 604800 = 7 days
MEMORY_TTL_SECONDS=86400
